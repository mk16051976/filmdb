
# ── PHP Upload-Limits ─────────────────────────────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 20M
    php_value post_max_size 25M
</IfModule>

# ── Security-Header ───────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Kein Clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Browser darf MIME-Typ nicht raten
    Header always set X-Content-Type-Options "nosniff"

    # Kein Referrer bei externen Links
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # XSS-Schutz (ältere Browser)
    Header always set X-XSS-Protection "1; mode=block"

    # HTTPS für 1 Jahr erzwingen (nach erstem Aufruf)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── favicon.ico → favicon.svg weiterleiten ────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # www → non-www (Duplikat-Domain vermeiden)
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

    # index.php → / (Duplikat-Canonical vermeiden)
    RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
    RewriteRule ^index\.php$ / [R=301,L]

    RewriteRule ^favicon\.ico$ /favicon.svg [R=301,L]
</IfModule>

# ── Verzeichnis-Listings deaktivieren ─────────────────────────────────────────
Options -Indexes

# ── Sensible Dateien direkt sperren ───────────────────────────────────────────
<FilesMatch "\.(sql|log|md|gitignore|env|ini)$">
    Require all denied
</FilesMatch>

# ── Browser-Caching für statische Assets ──────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # Cover-Bilder: 30 Tage
    <FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
        ExpiresDefault "access plus 30 days"
    </FilesMatch>
    # CSS/JS: 7 Tage
    <FilesMatch "\.(css|js)$">
        ExpiresDefault "access plus 7 days"
    </FilesMatch>
</IfModule>
<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>
